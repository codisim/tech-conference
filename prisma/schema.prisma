generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String?
  role      UserRole @default(USER)
  status    Status   @default(ACTIVE)

  refreshToken String?

  orders        Order[]
  tickets       Ticket[]
  reviews       Review[]
  notifications Notification[]
  payments      Payment[]
  organizer     Organizer?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@map("users")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  startDate   DateTime
  endDate     DateTime
  location    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizerId String
  organizer   Organizer @relation(fields: [organizerId], references: [id])

  sessions      Session[]
  tickets       Ticket[]
  venue         Venue?         @relation(fields: [venueId], references: [id])
  venueId       String?
  ticketTypes   TicketType[]
  orders        Order[]
  sponsors      Sponsor[]
  reviews       Review[]
  notifications Notification[]

  @@map("events")
}

model Organizer {
  id          String          @id @default(uuid())
  name        String
  companyName String
  contactInfo String
  status      OrganizerStatus @default(PENDING) // <-- changed from verified Boolean

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  events Event[]

  @@map("organizers")
}

model Venue {
  id        String   @id @default(uuid())
  name      String
  address   String
  mapLink   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events Event[]

  @@map("venues")
}

model Session {
  id        String   @id @default(uuid())
  title     String
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  speakers SessionSpeaker[]
  reviews  Review[]

  @@map("sessions")
}

model Speaker {
  id        String   @id @default(uuid())
  name      String
  bio       String
  photo     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions SessionSpeaker[]

  @@map("speakers")
}

model SessionSpeaker {
  id        String   @id @default(uuid())
  sessionId String
  speakerId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id])
  speaker Speaker @relation(fields: [speakerId], references: [id])

  @@map("session_speakers")
}

model TicketType {
  id           String   @id @default(uuid())
  name         String
  price        Decimal  @db.Decimal(10, 2)
  quantity     Int
  soldQuantity Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  tickets Ticket[]

  @@map("ticket_types")
}

model Ticket {
  id        String   @id @default(uuid())
  qrCode    String?
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId       String
  eventId      String
  ticketTypeId String
  orderId      String?

  user       User       @relation(fields: [userId], references: [id])
  event      Event      @relation(fields: [eventId], references: [id])
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
  order      Order?     @relation(fields: [orderId], references: [id])

  @@map("tickets")
}

model Order {
  id          String      @id @default(uuid())
  totalAmount Float
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  userId  String
  eventId String

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  payment Payment?
  tickets Ticket[]

  @@map("orders")
}

model Payment {
  id            String          @id @default(uuid())
  provider      PaymentProvider
  transactionId String?
  status        PaymentStatus   @default(PENDING)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  userId  String
  orderId String @unique

  user  User  @relation(fields: [userId], references: [id])
  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model Sponsor {
  id        String   @id @default(uuid())
  name      String
  tier      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  @@map("sponsors")
}

model Review {
  id      String  @id @default(uuid())
  rating  Int
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String
  eventId   String?
  sessionId String?

  user    User     @relation(fields: [userId], references: [id])
  event   Event?   @relation(fields: [eventId], references: [id])
  session Session? @relation(fields: [sessionId], references: [id])

  @@map("reviews")
}

model Notification {
  id         String    @id @default(uuid())
  message    String
  readStatus Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  userId  String
  eventId String?

  user  User   @relation(fields: [userId], references: [id])
  event Event? @relation(fields: [eventId], references: [id])

  @@map("notifications")
}

enum UserRole {
  USER
  ADMIN
  ORGANIZER
}

enum Status {
  ACTIVE
  INACTIVE
  CANCELLED
  COMPLETED
}

enum OrganizerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  SSL_COMMERZ
  PAYPAL
}
